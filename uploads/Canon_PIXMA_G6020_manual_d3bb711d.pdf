      "url": "https://www.manuals.co.uk/canon/pixma-g6020/manual",
      "text": "Do you have a particular question about the Canon PIXMA G6020 for which you cannot find the answer in the manual?",
      "datePublished": "2025-07-30T15:59:04.000Z",
      "dateModified": "2025-07-30T15:59:04.000Z",
      "isPartOf": "https://www.manuals.co.uk/canon/pixma-g6020/manual",
